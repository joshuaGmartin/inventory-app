<td class="actions-cell">
  <div class="actions-wrapper">
    <form action="/genres/edit" method="get">
      <input type="hidden" name="genre_id" value="<%= genre.id %>" />
      <button type="submit">Edit</button>
    </form>
    <form action="/genres/delete" method="post">
      <input type="hidden" name="genre_id" value="<%= genre.id %>" />
      <button
        type="submit"
        onclick="
          return confirm(
            'Are you sure you want to delete genre &quot;<%= genre.genre_name %>&quot; (id: <%= genre.id %>) and all of its associated films?',
          );
        "
      >
        Delete
      </button>
    </form>
  </div>
</td>
