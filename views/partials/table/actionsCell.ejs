<td class="actions-cell">
  <div class="actions-wrapper">
    <form action="/films/edit" method="get">
      <input type="hidden" name="film_id" value="<%= film.film_id %>" />
      <button type="submit">Edit</button>
    </form>
    <form action="/films/delete" method="post">
      <input type="hidden" name="film_id" value="<%= film.film_id %>" />
      <button
        type="submit"
        onclick="
          return confirm(
            'Are you sure you want to delete film &quot;<%= film.title %>&quot; (id: <%= film.film_id %>)?',
          );
        "
      >
        Delete
      </button>
    </form>
  </div>
</td>
